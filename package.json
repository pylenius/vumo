{
  "name": "vumo",
  "private": true,
  "version": "0.0.0",
  "description": "Make videos programmatically with Vue 3 — a Vue-native port of Remotion.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
