{
  "name": "vumo",
  "private": true,
  "version": "0.0.0",
  "description": "Make videos programmatically with Vue 3 — a Vue-native port of Remotion.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --filter @vumo/core --filter @vumo/renderer test",
    "dev:hello": "pnpm --filter @vumo/example-hello-world dev",
    "docs:dev": "pnpm --filter vumo-docs dev",
    "docs:build": "pnpm --filter vumo-docs build",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
