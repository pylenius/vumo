{
  "name": "@vumo/core",
  "version": "0.2.1",
  "description": "Vue primitives for vumo: useCurrentFrame, useVideoConfig, defineComposition, Sequence, Audio, delayRender.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./internals": {
      "types": "./src/internals/index.ts",
      "import": "./src/internals/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./internals": {
        "types": "./dist/internals/index.d.ts",
        "import": "./dist/internals.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^15.11.7",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  },
  "keywords": [
    "vue",
    "video",
    "remotion",
    "programmatic-video",
    "vumo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pylenius/vumo.git",
    "directory": "packages/core"
  },
  "license": "MIT"
}
